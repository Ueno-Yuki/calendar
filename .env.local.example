# Google Sheets API (サービスアカウント)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# Google Calendar API (OAuth2 - 母の初回認証で Refresh Token は sync_meta シートへ保存)
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_CALENDAR_ID_MOTHER=mother@gmail.com

# Push通知 (VAPID)
# VAPID_PUBLIC_KEY はサーバー側のPush送信で使用（PR12以降）
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# NEXT_PUBLIC_VAPID_PUBLIC_KEY はクライアント側のPush購読で使用（VAPID_PUBLIC_KEY と同じ値を設定）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# 家族認証トークン (長いランダム文字列を設定すること)
FAMILY_TOKEN_MOTHER=replace-with-long-random-string
FAMILY_TOKEN_FATHER=replace-with-long-random-string
FAMILY_TOKEN_ME=replace-with-long-random-string
FAMILY_TOKEN_BROTHER=replace-with-long-random-string

# Vercel Cron 認証シークレット (長いランダム文字列を設定すること)
# Vercel ダッシュボードの Environment Variables にも同じ値を設定する
# Vercel Cron は Authorization: Bearer <CRON_SECRET> を自動付与する
CRON_SECRET=replace-with-long-random-string
